{
  "name": "ai-cli",
  "version": "2.8.5.5",
  "description": "AI CLI — local + cloud LLM terminal toolkit with training, RLHF, Canvas, AUI and 195 curated models",
  "author": "minerofthesoal",
  "license": "MIT",
  "homepage": "https://github.com/minerofthesoal/ai-cli",
  "repository": {
    "type": "git",
    "url": "https://github.com/minerofthesoal/ai-cli.git"
  },
  "keywords": ["ai", "llm", "gguf", "llama", "cli", "rlhf", "training", "canvas", "tui"],
  "engines": {
    "python": ">=3.10",
    "bash": ">=5.0"
  },
  "scripts": {
    "install": "python3 install_v3.1.py",
    "install-deps": "pip install -r requirements.txt --break-system-packages",
    "test": "bash main.sh --version"
  },
  "dependencies": {
    "python3": ">=3.10.0",
    "curl": ">=7.0.0",
    "git": ">=2.0.0"
  },
  "optionalDependencies": {
    "ffmpeg": ">=4.0.0",
    "jq": ">=1.6",
    "gh": ">=2.0.0"
  },
  "peerDependencies": {
    "nodejs": ">=18.0.0"
  },
  "devDependencies": {
    "shellcheck": ">=0.8.0"
  },
  "_pythonDependencies": {
    "comment": "pip install these — see requirements.txt",
    "torch": ">=2.0.0",
    "transformers": ">=4.35.0",
    "accelerate": ">=0.24.0",
    "peft": ">=0.6.0",
    "trl": ">=0.7.0",
    "datasets": ">=2.14.0",
    "huggingface_hub": ">=0.19.0",
    "llama-cpp-python": ">=0.2.0",
    "openai": ">=1.0.0",
    "anthropic": ">=0.20.0",
    "google-generativeai": ">=0.3.0",
    "diffusers": ">=0.24.0",
    "sentencepiece": ">=0.1.99",
    "bitsandbytes": ">=0.41.0",
    "scipy": ">=1.11.0",
    "numpy": ">=1.24.0",
    "pillow": ">=10.0.0",
    "requests": ">=2.31.0",
    "rich": ">=13.0.0",
    "tiktoken": ">=0.5.0",
    "whisper": ">=1.0.0",
    "TTS": ">=0.22.0",
    "sentence-transformers": ">=2.2.0",
    "faiss-cpu": ">=1.7.4",
    "einops": ">=0.7.0",
    "safetensors": ">=0.4.0",
    "tokenizers": ">=0.15.0"
  },
  "main": "main.sh",
  "files": [
    "main.sh",
    "install_v3.1.py",
    "requirements.txt",
    "README.md",
    "LICENSE"
